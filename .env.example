# Environment Variables — reference for all deploy targets
#
# Copy to .env for local development. NEVER commit .env.

# ── Google Sheets (monitor engine, backend, scripts) ─────────────────────────
# Spreadsheet ID from the sheet URL: docs.google.com/spreadsheets/d/<THIS>/edit
SHEET_ID=your_google_sheet_id_here
# Service-account JSON key, base64-encoded:  base64 -w0 service-account.json
# Share the spreadsheet with the service account email as Editor.
GOOGLE_SERVICE_ACCOUNT_JSON_B64=your_base64_encoded_service_account_json_here

# ── Storage repo / GitHub Pages ──────────────────────────────────────────────
# Public base URL of the storage repo's GitHub Pages site (no trailing slash)
PAGES_BASE_URL=https://github.com/priyanshu-devops/enterprise-uptime-storage.git

# ── Backend (Render) ─────────────────────────────────────────────────────────
PORT=8080
NODE_ENV=development
# Single admin login
ADMIN_EMAIL=admin@example.com
# bcrypt hash of the admin password:  node -e "console.log(require('bcryptjs').hashSync('yourpassword', 10))"
ADMIN_PASSWORD_HASH=$2a$10$4ISdw33.LFVU4mYRSYX.GO8FBucVJyZ0N5Mf7LKXLgwXYVv9KpPKq
# Random 32+ char secret:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=24h
# Comma-separated CORS allowlist
FRONTEND_ORIGIN=http://localhost:3000
# Fine-grained PAT: Actions read/write on code repo, Contents read/write on storage repo
GITHUB_TOKEN=your_github_personal_access_token_here
GITHUB_OWNER=priyanshu-devops
CODE_REPO=uptime-platform
STORAGE_REPO=uptime-storage
CACHE_TTL_SECONDS=300
# Set to 1 to boot the backend with in-memory demo data (no Google Sheet needed)
MOCK_DATA=

# ── Frontend (Vercel) ────────────────────────────────────────────────────────
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080
NEXT_PUBLIC_PAGES_BASE_URL=https://<user>.github.io/<storage-repo>
NEXT_PUBLIC_APP_NAME=Uptime Platform

# ── Monitor engine tuning (GitHub Actions vars / local) ──────────────────────
HTTP_POOL=20
SCREENSHOT_POOL=4
RDAP_POOL=5
CHECK_TIMEOUT_MS=10000

# ── Supabase (Frontend/Backend) ────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://fcgyymsthkbufgmplrub.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_VmGYe4faKSMnXRm3cmYIQg_Fi9ZoSmy
