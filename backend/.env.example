# Backend environment variables
# Copy to .env and fill in values for local development.
# In production (Render), set these in the dashboard.

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development
LOG_LEVEL=info

# Set to "1" to run with in-memory fakes (no Google Sheets / GitHub needed)
MOCK_DATA=

# ─── Auth ─────────────────────────────────────────────────────────────────────
ADMIN_EMAIL=admin@example.com
# Generate with: node -e "console.log(require('bcryptjs').hashSync('yourpassword', 10))"
ADMIN_PASSWORD_HASH=
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRn
# ─── CORS ──────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins (empty = allow all in dev)
FRONTEND_ORIGIN=http://localhost:3000

# ─── Google Sheets ────────────────────────────────────────────────────────────
SHEET_ID=
# Base64-encoded service account JSON:
#   cat service-account.json | base64 -w0
GOOGLE_SERVICE_ACCOUNT_JSON_B64=

# ─── GitHub (for triggering workflows + reading runs) ─────────────────────────
GITHUB_TOKEN=
GITHUB_OWNER=
CODE_REPO=
STORAGE_REPO=

# ─── GitHub Pages storage (for logs, cache fallback) ──────────────────────────
# e.g. https://youruser.github.io/uptime-storage
PAGES_BASE_URL=

# ─── Caching ──────────────────────────────────────────────────────────────────
CACHE_TTL_SECONDS=300
