{
  "name": "@uptime/backend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "REST API for the enterprise website-monitoring platform",
  "main": "./dist/server.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
