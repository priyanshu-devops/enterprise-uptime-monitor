# Frontend environment variables
# Copy to .env.local for local development.
# In production (Vercel), set these in the dashboard.

# Backend API URL (local dev = localhost:4000, production = your Render URL)
# No trailing slash, no /api/v1 suffix
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000

# GitHub Pages storage URL for cache fallback when backend is cold-starting
# e.g. https://youruser.github.io/uptime-storage
NEXT_PUBLIC_PAGES_BASE_URL=https://github.com/priyanshu-devops/enterprise-uptime-storage.git

# App display name (shown in sidebar and login page)
NEXT_PUBLIC_APP_NAME=Uptime Monitor
