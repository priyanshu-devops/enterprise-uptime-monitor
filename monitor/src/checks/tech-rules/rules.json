{
  "$comment": "Technology fingerprint rules. Each rule matches against response headers, cookies, HTML body, and generator meta. Ordered by specificity; the tech stage dedupes results. Wappalyzer OSS is defunct, so this is a curated, maintainable subset covering the platform's target stacks.",
  "cms": [
    { "name": "WordPress", "html": ["wp-content", "wp-includes", "/wp-json"], "generator": ["WordPress"], "wordpress": true },
    { "name": "Shopify", "headers": { "x-shopify-stage": ".*", "x-sorting-hat-shopid": ".*" }, "html": ["cdn.shopify.com", "Shopify.theme"] },
    { "name": "Wix", "headers": { "x-wix-request-id": ".*" }, "html": ["static.wixstatic.com", "wix.com"] },
    { "name": "Squarespace", "html": ["static1.squarespace.com", "squarespace.com"], "generator": ["Squarespace"] },
    { "name": "Drupal", "headers": { "x-drupal-cache": ".*", "x-generator": "Drupal" }, "html": ["/sites/default/files", "Drupal.settings"], "generator": ["Drupal"] },
    { "name": "Joomla", "html": ["/media/jui/", "com_content"], "generator": ["Joomla"] },
    { "name": "Ghost", "html": ["ghost.io", "content=\"Ghost"], "generator": ["Ghost"] },
    { "name": "Webflow", "html": ["assets.website-files.com", "webflow.com"], "generator": ["Webflow"] },
    { "name": "HubSpot", "html": ["hs-scripts.com", "hubspot.com"] },
    { "name": "Magento", "html": ["Magento_", "/static/version", "mage/cookies"] }
  ],
  "framework": [
    { "name": "Next.js", "headers": { "x-powered-by": "Next.js" }, "html": ["/_next/static", "__NEXT_DATA__"] },
    { "name": "Nuxt.js", "html": ["/_nuxt/", "__NUXT__"] },
    { "name": "Gatsby", "html": ["/page-data/", "___gatsby"] },
    { "name": "Remix", "html": ["__remixContext", "/build/_shared/"] },
    { "name": "SvelteKit", "html": ["/_app/immutable/", "__sveltekit"] },
    { "name": "Astro", "html": ["astro-island", "/_astro/"], "generator": ["Astro"] },
    { "name": "React", "html": ["react.production.min.js", "data-reactroot", "_reactListening"] },
    { "name": "Vue.js", "html": ["vue.runtime", "data-v-", "__vue__"] },
    { "name": "Angular", "html": ["ng-version", "ng-app", "angular.min.js"] },
    { "name": "Ruby on Rails", "headers": { "x-powered-by": "Phusion Passenger" }, "html": ["csrf-param", "rails"] },
    { "name": "Laravel", "cookies": ["laravel_session", "XSRF-TOKEN"] },
    { "name": "Django", "cookies": ["csrftoken", "django"] },
    { "name": "Express", "headers": { "x-powered-by": "Express" } },
    { "name": "ASP.NET", "headers": { "x-powered-by": "ASP.NET", "x-aspnet-version": ".*" }, "cookies": ["ASP.NET_SessionId"] }
  ],
  "cdn": [
    { "name": "Cloudflare", "headers": { "cf-ray": ".*", "server": "cloudflare" }, "cloudflare": true },
    { "name": "Fastly", "headers": { "x-served-by": "cache-", "x-fastly-request-id": ".*", "fastly-io-info": ".*" } },
    { "name": "Amazon CloudFront", "headers": { "x-amz-cf-id": ".*", "via": "CloudFront" } },
    { "name": "Akamai", "headers": { "x-akamai-transformed": ".*", "akamai-grn": ".*" } },
    { "name": "Vercel", "headers": { "x-vercel-id": ".*", "server": "Vercel" } },
    { "name": "Netlify", "headers": { "x-nf-request-id": ".*", "server": "Netlify" } },
    { "name": "Sucuri", "headers": { "x-sucuri-id": ".*", "x-sucuri-cache": ".*" } },
    { "name": "Imperva", "headers": { "x-iinfo": ".*", "x-cdn": "Incapsula" } },
    { "name": "KeyCDN", "headers": { "server": "keycdn" } },
    { "name": "BunnyCDN", "headers": { "server": "BunnyCDN" } },
    { "name": "Google Cloud CDN", "headers": { "via": "google" } }
  ],
  "server": [
    { "name": "nginx", "headers": { "server": "nginx" } },
    { "name": "Apache", "headers": { "server": "Apache" } },
    { "name": "Microsoft IIS", "headers": { "server": "Microsoft-IIS" } },
    { "name": "LiteSpeed", "headers": { "server": "LiteSpeed" } },
    { "name": "Caddy", "headers": { "server": "Caddy" } },
    { "name": "Google Frontend", "headers": { "server": "gws|Google Frontend" } }
  ],
  "analytics": [
    { "name": "Google Analytics", "html": ["google-analytics.com/analytics.js", "gtag/js", "googletagmanager.com/gtag"] },
    { "name": "Google Tag Manager", "html": ["googletagmanager.com/gtm.js"] },
    { "name": "Plausible", "html": ["plausible.io/js"] },
    { "name": "Hotjar", "html": ["static.hotjar.com"] },
    { "name": "Segment", "html": ["cdn.segment.com/analytics.js"] }
  ]
}
